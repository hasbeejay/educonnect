@using EduConnect.Models
@using EduConnect.Services
@inject AuthStateService AuthState

<div class="role-layout">
    @if (!string.IsNullOrEmpty(Title))
    {
        <div class="role-header mb-4">
            <div class="d-flex align-items-center">
                <div class="role-icon me-3">
                    @if (AuthState.State.IsAdmin)
                    {
                        <i class="bi bi-shield-check display-4 text-primary"></i>
                    }
                    else if (AuthState.State.IsFaculty)
                    {
                        <i class="bi bi-person-badge display-4 text-success"></i>
                    }
                    else if (AuthState.State.IsStudent)
                    {
                        <i class="bi bi-mortarboard display-4 text-info"></i>
                    }
                    else
                    {
                        <i class="bi bi-person display-4 text-secondary"></i>
                    }
                </div>
                <div>
                    <h2 class="mb-1">@Title</h2>
                    <p class="text-muted mb-0">
                        <i class="bi bi-person-circle me-1"></i>
                        @AuthState.State.CurrentUser?.FullName
                        <span class="badge ms-2 @GetRoleBadgeClass()">@AuthState.State.Role</span>
                    </p>
                </div>
            </div>
            @if (!string.IsNullOrEmpty(Description))
            {
                <p class="mt-3 text-muted">@Description</p>
            }
        </div>
    }

    <div class="role-content">
        @ChildContent
    </div>

    @if (ShowStats && AuthState.State.IsAuthenticated)
    {
        <div class="role-stats mt-5 pt-4">
            <h5 class="mb-3 section-eyebrow">
                <i class="bi bi-graph-up me-2"></i>
                Quick Stats
            </h5>
            <div class="row">
                @if (AuthState.State.IsAdmin)
                {
                    <div class="col-md-3 mb-3">
                        <div class="card stat-card h-100">
                            <div class="card-body text-center">
                                <div class="stat-icon d-inline-flex position-static mb-2">
                                    <i class="bi bi-people-fill"></i>
                                </div>
                                <div class="stat-label">Total Students</div>
                                <div class="stat-value text-primary">@GetStudentCount()</div>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-3 mb-3">
                        <div class="card stat-card h-100">
                            <div class="card-body text-center">
                                <div class="stat-icon d-inline-flex position-static mb-2">
                                    <i class="bi bi-journal-bookmark-fill"></i>
                                </div>
                                <div class="stat-label">Active Courses</div>
                                <div class="stat-value text-success">@GetCourseCount()</div>
                            </div>
                        </div>
                    </div>
                }
                else if (AuthState.State.IsFaculty)
                {
                    <div class="col-md-3 mb-3">
                        <div class="card stat-card h-100">
                            <div class="card-body text-center">
                                <div class="stat-icon d-inline-flex position-static mb-2">
                                    <i class="bi bi-collection-fill"></i>
                                </div>
                                <div class="stat-label">Assigned Courses</div>
                                <div class="stat-value text-success">@GetFacultyCourseCount()</div>
                            </div>
                        </div>
                    </div>
                }
                else if (AuthState.State.IsStudent)
                {
                    <div class="col-md-3 mb-3">
                        <div class="card stat-card h-100">
                            <div class="card-body text-center">
                                <div class="stat-icon d-inline-flex position-static mb-2">
                                    <i class="bi bi-award-fill"></i>
                                </div>
                                <div class="stat-label">Current CGPA</div>
                                <div class="stat-value text-info">@GetStudentCGPA()</div>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-3 mb-3">
                        <div class="card stat-card h-100">
                            <div class="card-body text-center">
                                <div class="stat-icon d-inline-flex position-static mb-2">
                                    <i class="bi bi-journal-bookmark-fill"></i>
                                </div>
                                <div class="stat-label">Enrolled Courses</div>
                                <div class="stat-value text-warning">@GetStudentEnrollmentCount()</div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    }
</div>

<style>
    .role-stats .stat-icon {
        position: static;
        width: 48px;
        height: 48px;
        margin: 0 auto;
        background: rgba(255, 101, 63, 0.15);
        border-radius: 12px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 1.4rem;
        backdrop-filter: blur(4px);
    }
    
    .role-stats .stat-card .card-body {
        padding: 1.5rem;
    }
    
    .role-stats .stat-value {
        font-size: 2rem;
    }
</style>

@code {
    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    [Parameter]
    public string? Title { get; set; }

    [Parameter]
    public string? Description { get; set; }

    [Parameter]
    public bool ShowStats { get; set; } = true;

    private string GetRoleBadgeClass()
    {
        return AuthState.State.Role switch
        {
            "Admin" => "bg-primary",
            "Faculty" => "bg-success",
            "Student" => "bg-info",
            _ => "bg-secondary"
        };
    }

    private int GetStudentCount()
    {
        return SeedData.Students.Count;
    }

    private int GetCourseCount()
    {
        return SeedData.Courses.Count;
    }

    private int GetFacultyCourseCount()
    {
        if (AuthState.State.CurrentUser is global::EduConnect.Models.Faculty faculty)
        {
            return faculty.AssignedCourses.Count;
        }
        return 0;
    }

    private string GetStudentCGPA()
    {
        if (AuthState.State.CurrentUser is global::EduConnect.Models.Student student)
        {
            return student.CGPA.ToString("0.00");
        }
        return "0.00";
    }

    private int GetStudentEnrollmentCount()
    {
        if (AuthState.State.CurrentUser is global::EduConnect.Models.Student student)
        {
            return student.Enrollments.Count;
        }
        return 0;
    }
}